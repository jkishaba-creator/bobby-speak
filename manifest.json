{
  "manifest_version": 3,
  "name": "AirFlow Dictation",
  "version": "0.2.0",
  "description": "Voice dictation for the browser, in the Air OS design language. Press the shortcut, speak, and text lands at your cursor.",
  "permissions": ["offscreen", "storage", "activeTab", "scripting", "clipboardWrite"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AirFlow Dictation",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "commands": {
    "toggle-dictation": {
      "suggested_key": { "default": "Ctrl+Shift+Space", "mac": "Command+Shift+Space" },
      "description": "Start / stop dictation"
    },
    "open-popout": {
      "suggested_key": { "default": "Ctrl+Shift+O", "mac": "Command+Shift+O" },
      "description": "Open the pop-out (dictate for other apps)"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
