<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/bobby_keyboard_surface" />
        </shape>
    </item>
    <item
        android:bottom="14dp"
        android:left="14dp"
        android:right="14dp"
        android:top="14dp">
        <shape android:shape="oval">
            <gradient
                android:angle="315"
                android:centerColor="#B9BBC7"
                android:endColor="#FBFBFD"
                android:startColor="#8B8D9C"
                android:type="linear" />
            <stroke
                android:width="1dp"
                android:color="@color/bobby_card_line" />
        </shape>
    </item>
</layer-list>
