<?xml version="1.0" encoding="utf-8"?>
<!-- Air OS card: face color, 22dp corners, 1dp hairline border (bobby-speak.pages.dev) -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/bobby_card_face" />
    <stroke
        android:width="1dp"
        android:color="@color/bobby_card_line" />
    <corners android:radius="22dp" />
</shape>
