<?xml version="1.0" encoding="utf-8"?>
<!-- Unselected Type/Tone: muted grey. Black is reserved for selected pills. -->
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/bobby_toolbar_pressed">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/bobby_key_utility" />
            <stroke
                android:width="1dp"
                android:color="@color/bobby_card_line" />
            <corners android:radius="999dp" />
        </shape>
    </item>
</ripple>
