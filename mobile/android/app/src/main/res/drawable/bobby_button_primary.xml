<?xml version="1.0" encoding="utf-8"?>
<!-- Air OS pillbtn-dark: ink face, pill radius. Brand orange is recording-only. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/bobby_disabled" />
            <corners android:radius="999dp" />
        </shape>
    </item>
    <item>
        <ripple android:color="@color/bobby_ripple_on_primary">
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/bobby_pill_primary_bg" />
                    <corners android:radius="999dp" />
                </shape>
            </item>
        </ripple>
    </item>
</selector>
